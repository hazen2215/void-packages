-        const label = lab: {
-            if (pin.metadata.get("name")) |name| break :lab name;
-            if (pin.handle) |h| break :lab h;
-            break :lab "";
-        };
-
-        try mepo.blit_multiline_text(
-            label_color,
-            pin_label_border,
-            pin_label_bg,

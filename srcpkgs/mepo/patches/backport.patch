+        0x000000,
+        null,
+        null,
+        .{ .align_x = .Right },
+        0,
+        @intCast(i32, mepo.win_h) - bottombar_height + 3,
+        null,
+        "Dl: {d:.2}Mb ",
+        .{@intToFloat(f32, mepo.tile_cache.byte_counter) / 1024 / 1024},

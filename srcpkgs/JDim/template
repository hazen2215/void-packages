build_options="alsa openssl"
build_options_default="alsa"

if [ "$build_option_openssl" ]; then
	# OpenSSL license is incompatible with GPL-2.0-only
	restricted=yes
fi

if [ "$CROSS_BUILD" ]; then
	hostmakedepends+=" gdk-pixbuf-devel"
fi

# Template file for 'lowdown'
pkgname=lowdown
version=1.4.0
revision=1
build_style=configure
configure_args="PREFIX=/usr MANDIR=/usr/share/man"
make_install_target="install install_libs"
make_check_target="regress"
short_desc="Simple markdown translator"
maintainer="Duncaen <duncaen@voidlinux.org>"
license="ISC"
homepage="https://kristaps.bsd.lv/lowdown/"
changelog="https://kristaps.bsd.lv/lowdown/archive.html"
distfiles="https://kristaps.bsd.lv/lowdown/snapshots/lowdown-${version}.tar.gz"
checksum=75bf8ddc66f6c75ebb64131ced1e729983a38f866a93878fc1753df93330e0ef

post_install() {
	vlicense LICENSE.md
}

lowdown-devel_package() {
	depends="${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.a"
		if false; then
		vmove "usr/lib/*.so"
		fi
		vmove "usr/share/man/man3/*.3"
	}
}

build_options="static"
build_options_default="static"
if [ "$build_option_static" ]; then
	configure_args+=" LDFLAGS=-static"
	make_build_target="bins lowdown.pc"
	make_install_target="install install_static"
fi

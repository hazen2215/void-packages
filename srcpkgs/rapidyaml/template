# Template file for 'rapidyaml'
pkgname=rapidyaml
version=0.5.0
revision=1
_c4core=869f64593421835930c582973c6c6d30889ac955
_cmake=95b2410e31ebf28b56a4fffffef52c7d13d657ad
_debugbreak=5dcbe41d2bd4712c8014aa7e843723ad7b40fd74
_fast_float=5.2.0
build_wrksrc="rapidyaml-${version}"
build_style=cmake
configure_args="-DBUILD_SHARED_LIBS=ON -DRYML_BUILD_API=ON"
hostmakedepends="cmake git ninja pkgconf python3 swig"
makedepends="python3-devel"
short_desc="Library to parse and emit yaml"
maintainer="hazen2215 <haz@disroot.org>"
license="MIT"
homepage="https://github.com/biojppm/rapidyaml"
distfiles="https://github.com/biojppm/rapidyaml/archive/refs/tags/v${version}.tar.gz
 https://github.com/biojppm/c4core/archive/${_c4core}.tar.gz
 https://github.com/biojppm/cmake/archive/${_cmake}.tar.gz
 https://github.com/biojppm/debugbreak/archive/${_debugbreak}.tar.gz
 https://github.com/fastfloat/fast_float/archive/refs/tags/v${_fast_float}.tar.gz"
checksum="8cad74d721ebab6f6e4909a9622ca27491c3b742782f55db4991a0b9de7422f3
 3f18ba1eec3b59329aefe03728a694abe858f88289f5d3fd162f55f6923af73f
 6b124fda0f4774123c002b2099b9513987062cdef1f9cb635cf4b95d967ac91b
 4b424d23dad957937c57c142648d32571a78a6c6b2e473709748e5c1bb8a0f92
 72bbfd1914e414c920e39abdc81378adf910a622b62c45b4c61d344039425d18"

post_extract() {
	rmdir ${build_wrksrc}/ext/c4core
	mv c4core-${_c4core} ${build_wrksrc}/ext/c4core
	rmdir ${build_wrksrc}/ext/c4core/cmake
	mv cmake-${_cmake} ${build_wrksrc}/ext/c4core/cmake
	rmdir ${build_wrksrc}/ext/c4core/src/c4/ext/debugbreak
	mv debugbreak-${_debugbreak} ${build_wrksrc}/ext/c4core/src/c4/ext/debugbreak
	rmdir ${build_wrksrc}/ext/c4core/src/c4/ext/fast_float
	mv fast_float-${_fast_float} ${build_wrksrc}/ext/c4core/src/c4/ext/fast_float

}

post_install() {
	vlicense LICENSE.txt
	# not linked from submodule..
	for f in ${DESTDIR}/usr/lib/libc4core*; do
		unlink $f
	done
	# trash
	rm ${DESTDIR}/usr/ryml.py
	rm ${DESTDIR}/usr/_ryml.so
}

rapidyaml-devel_package() {
	depends="${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}

# Template file for 'htop'
pkgname=htop
version=3.3.0
revision=1
build_style=gnu-configure
configure_args="--enable-unicode --enable-sensors"
makedepends="ncurses-devel libsensors-devel"
short_desc="Interactive process viewer"
maintainer="Frank Steinborn <steinex@nognu.de>"
license="GPL-2.0-only"
build_options="netbsd_curses static sensors"
build_options_default="netbsd_curses static"
configure_args="${configure_args/--enable-unicode/}"
configure_args="${configure_args/--enable-sensors/}
 $(vopt_enable sensors) $(vopt_enable static)"
makedepends="${makedepends/ncurses-devel/}"
makedepends="${makedepends/libsensor-devel/} $(vopt_if sensors libsensors-devel)"
if [ "$build_option_netbsd_curses" ]; then
	configure_args+=" --disable-unicode"
	makedepends+=" netbsd-curses-devel"
	export LIBS="-lterminfo"
else
	configure_args+=" --enable-unicode"
	makedepends+=" ncurses-devel"
fi
homepage="https://htop.dev/"
changelog="https://raw.githubusercontent.com/htop-dev/htop/main/ChangeLog"
distfiles="https://github.com/htop-dev/htop/releases/download/${version}/htop-${version}.tar.xz"
checksum=a69acf9b42ff592c4861010fce7d8006805f0d6ef0e8ee647a6ee6e59b743d5c

# Template file for 'oasis-libfido2'
pkgname=oasis-libfido2
version=1.9.0
revision=1
_commit=84c53f0046fa0040a8a31097167d27111a9624c4
build_style=cmake
hostmakedepends="pkg-config"
makedepends="libcbor-devel zlib-devel bearssl-devel"
short_desc="Library for FIDO 2.0, including communication with a device over USB"
maintainer="hazen2215 <haz@disroot.org>"
license="BSD-2-Clause"
homepage="https://github.com/oasislinux/libfido2"
distfiles="https://github.com/oasislinux/libfido2/archive/${_commit}.tar.gz"
changelog="https://github.com/oasislinux/libfido2/blob/main/NEWS"
checksum=1fe71fd1a41a515fa6599f23041a5d8eb7cec09e89f0bf15b8b5727eb26b6a98

post_extract() {
	vsed -i -e '/add_compile_options(-Werror)/d' CMakeLists.txt
	vsed -i -e '/NFC_LINUX ON/d' CMakeLists.txt
}

post_install() {
	rm ${DESTDIR}/usr/lib/*.so*
	vlicense LICENSE
}

oasis-libfido2-devel_package() {
	short_desc+=" - development files"
	# depends="${sourcepkg}>=${version}_${revision} libcbor-devel"
	depends="libcbor-static-devel"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/*.a
		vmove usr/lib/pkgconfig
		vmove usr/share/man/man3
	}
}
